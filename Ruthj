        <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>For Ruth - From Jude</title>
    <style>
        :root {
            --pink: #ff1493;
            --soft-pink: #ff85a2;
            --dark: #0a0005;
        }

        body {
            margin: 0;
            overflow: hidden;
            background: var(--dark);
            font-family: 'Segoe UI', system-ui, sans-serif;
            color: white;
            touch-action: none;
        }

        /* UI Layers */
        #ui-container {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 100;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 20px;
            box-sizing: border-box;
        }

        /* Top Section: Header & Voice */
        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            pointer-events: auto;
        }

        .voice-btn {
            background: rgba(255, 20, 147, 0.2);
            border: 1px solid var(--pink);
            color: white;
            padding: 10px 15px;
            border-radius: 12px;
            cursor: pointer;
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Center Section: Surprise Card & Gallery */
        #surprise-card, #gallery-card {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.9);
            background: rgba(10, 0, 5, 0.95);
            border: 1px solid var(--pink);
            padding: 30px;
            border-radius: 24px;
            text-align: center;
            width: 85%;
            max-width: 400px;
            display: none;
            opacity: 0;
            pointer-events: auto;
            transition: 0.4s all ease;
            box-shadow: 0 0 40px rgba(255, 20, 147, 0.3);
        }

        .active-card {
            display: block !important;
            opacity: 1 !important;
            transform: translate(-50%, -50%) scale(1) !important;
        }

        /* Memories Gallery Styling */
        .polaroid-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-top: 15px;
        }

        .polaroid {
            background: white;
            padding: 5px 5px 15px 5px;
            transform: rotate(-3deg);
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
        }

        .polaroid:nth-child(even) { transform: rotate(3deg); }

        .polaroid img {
            width: 100%;
            height: 80px;
            object-fit: cover;
            background: #eee;
        }

        .polaroid p {
            color: #333;
            font-size: 0.6rem;
            margin: 5px 0 0 0;
            font-family: 'Cursive', sans-serif;
        }

        /* Bottom Section: Countdown & Brand */
        .bottom-info {
            text-align: center;
            pointer-events: auto;
        }

        #countdown {
            font-size: 0.9rem;
            color: var(--soft-pink);
            background: rgba(0,0,0,0.5);
            padding: 8px 20px;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 10px;
            border: 1px solid rgba(255, 133, 162, 0.3);
        }

        .brand-text {
            font-size: 0.65rem;
            letter-spacing: 3px;
            opacity: 0.5;
            text-transform: uppercase;
        }

        .nav-btns {
            margin-top: 10px;
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .nav-btn {
            background: rgba(255, 255, 255, 0.1);
            border: none;
            color: white;
            padding: 8px 15px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.8rem;
        }

        .close-btn {
            background: var(--pink);
            border: none;
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            margin-top: 20px;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <div id="ui-container">
        <div class="top-bar">
            <div>
                <h2 style="margin:0; color: var(--soft-pink);">Ruth & Jude</h2>
            </div>
            <button class="voice-btn" onclick="speakMessage()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line x1="12" y1="19" x2="12" y2="23"></line><line x1="8" y1="23" x2="16" y2="23"></line></svg>
                Listen
            </button>
        </div>

        <div id="surprise-card">
            <h2 style="color: var(--pink);">A Message for Ruth</h2>
            <p>Meeting you, Ruth, felt like a scene from a movie. You have this incredible energy that just brightens everything up.</p>
            <p>I hope this 3D world I built for you reminds you of how special you are.</p>
            <p style="font-weight: bold;">- Jude</p>
            <button class="close-btn" onclick="hideAllCards()">Close</button>
        </div>

        <div id="gallery-card">
            <h2 style="color: var(--pink);">Our Moments</h2>
            <div class="polaroid-grid">
                <div class="polaroid">
                    <img src="https://images.unsplash.com/photo-1516589174184-c662ff299107?auto=format&fit=crop&w=200" alt="Meeting">
                    <p>The First Day</p>
                </div>
                <div class="polaroid">
                    <img src="https://images.unsplash.com/photo-1518199266791-5375a83190b7?auto=format&fit=crop&w=200" alt="Smile">
                    <p>That Smile</p>
                </div>
            </div>
            <button class="close-btn" onclick="hideAllCards()" style="margin-top:30px">Back</button>
        </div>

        <div class="bottom-info">
            <div id="countdown">Loading countdown...</div>
            <div class="nav-btns">
                <button class="nav-btn" onclick="showCard('surprise-card')">The Letter</button>
                <button class="nav-btn" onclick="showCard('gallery-card')">Memories</button>
            </div>
            <p class="brand-text">Created by Judenet IntelliSoft Solutions</p>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

    <script>
        let scene, camera, renderer, heart, flowerParticles = [];
        const apiKey = ""; // Gemini API key for TTS

        function init() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.z = 10;

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(window.devicePixelRatio);
            document.body.appendChild(renderer.domElement);

            // 3D Heart Setup
            const heartShape = new THREE.Shape();
            const x = 0, y = 0;
            heartShape.moveTo( x + 5, y + 5 );
            heartShape.bezierCurveTo( x + 5, y + 5, x + 4, y, x, y );
            heartShape.bezierCurveTo( x - 6, y, x - 6, y + 7,x - 6, y + 7 );
            heartShape.bezierCurveTo( x - 6, y + 11, x - 3, y + 15.4, x + 5, y + 19 );
            heartShape.bezierCurveTo( x + 12, y + 15.4, x + 16, y + 11, x + 16, y + 7 );
            heartShape.bezierCurveTo( x + 16, y + 7, x + 16, y, x + 10, y );
            heartShape.bezierCurveTo( x + 7, y, x + 5, y + 5, x + 5, y + 5 );

            const geometry = new THREE.ExtrudeGeometry(heartShape, { depth: 2, bevelEnabled: true, bevelSize: 1 });
            geometry.center();
            const material = new THREE.MeshPhongMaterial({ color: 0xff1493, shininess: 100 });
            heart = new THREE.Mesh(geometry, material);
            heart.scale.set(0.2, 0.2, 0.2);
            heart.rotation.x = Math.PI;
            scene.add(heart);

            // Lighting
            const light = new THREE.PointLight(0xffffff, 1, 100);
            light.position.set(10, 10, 10);
            scene.add(light);
            scene.add(new THREE.AmbientLight(0xffffff, 0.6));

            // Interaction for Flowers
            window.addEventListener('pointerdown', handleInteraction);
            window.addEventListener('resize', onResize);
            
            updateCountdown();
            setInterval(updateCountdown, 1000);
            animate();
        }

        function handleInteraction(e) {
            if (e.target.tagName === 'BUTTON') return;
            spawnFlower(e.clientX, e.clientY);
        }

        function spawnFlower(x, y) {
            // Convert screen to 3D coords
            const vector = new THREE.Vector3(
                (x / window.innerWidth) * 2 - 1,
                -(y / window.innerHeight) * 2 + 1,
                0.5
            );
            vector.unproject(camera);
            const dir = vector.sub(camera.position).normalize();
            const distance = -camera.position.z / dir.z;
            const pos = camera.position.clone().add(dir.multiplyScalar(distance));

            // Simple Flower (using grouped spheres for petals)
            const flower = new THREE.Group();
            const petalGeom = new THREE.SphereGeometry(0.2, 8, 8);
            const petalMat = new THREE.MeshPhongMaterial({ color: 0xff69b4 });
            
            for(let i=0; i<5; i++) {
                const petal = new THREE.Mesh(petalGeom, petalMat);
                petal.position.x = Math.cos(i * Math.PI * 0.4) * 0.3;
                petal.position.y = Math.sin(i * Math.PI * 0.4) * 0.3;
                flower.add(petal);
            }
            
            flower.position.copy(pos);
            scene.add(flower);
            flowerParticles.push({
                mesh: flower,
                velocity: new THREE.Vector3((Math.random()-0.5)*0.05, 0.05 + Math.random()*0.05, (Math.random()-0.5)*0.05),
                life: 1.0
            });
        }

        function showCard(id) {
            hideAllCards();
            document.getElementById(id).classList.add('active-card');
        }

        function hideAllCards() {
            document.querySelectorAll('#surprise-card, #gallery-card').forEach(c => c.classList.remove('active-card'));
        }

        function updateCountdown() {
            // Set to a future date - e.g., next Friday
            const nextMeeting = new Date();
            nextMeeting.setDate(nextMeeting.getDate() + (5 + 7 - nextMeeting.getDay()) % 7);
            nextMeeting.setHours(18, 0, 0, 0);

            const now = new Date();
            const diff = nextMeeting - now;

            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
            const mins = Math.floor((diff / 1000 / 60) % 60);
            const secs = Math.floor((diff / 1000) % 60);

            document.getElementById('countdown').innerText = `Time until I see Ruth: ${days}d ${hours}h ${mins}m ${secs}s`;
        }

        async function speakMessage() {
            const text = "Say cheerfully: Hi Ruth! This is Jude. I built this 3D world just for you. Every heart and flower you see here represents how happy I am that we met. You are truly special.";
            
            try {
                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-tts:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text }] }],
                        generationConfig: {
                            responseModalities: ["AUDIO"],
                            speechConfig: { voiceConfig: { prebuiltVoiceConfig: { voiceName: "Puck" } } }
                        }
                    })
                });

                const data = await response.json();
                const pcmData = data.candidates[0].content.parts[0].inlineData.data;
                playWavFromPcm(pcmData);
            } catch (err) {
                console.error("TTS Error:", err);
            }
        }

        function playWavFromPcm(base64Pcm) {
            const binary = atob(base64Pcm);
            const arrayBuffer = new ArrayBuffer(binary.length);
            const view = new Uint8Array(arrayBuffer);
            for (let i = 0; i < binary.length; i++) view[i] = binary.charCodeAt(i);
            
            const wavHeader = createWavHeader(binary.length, 24000);
            const blob = new Blob([wavHeader, view], { type: 'audio/wav' });
            const url = URL.createObjectURL(blob);
            const audio = new Audio(url);
            audio.play();
        }

        function createWavHeader(dataLength, sampleRate) {
            const buffer = new ArrayBuffer(44);
            const view = new DataView(buffer);
            const writeString = (offset, string) => {
                for (let i = 0; i < string.length; i++) view.setUint8(offset + i, string.charCodeAt(i));
            };
            writeString(0, 'RIFF');
            view.setUint32(4, 36 + dataLength, true);
            writeString(8, 'WAVE');
            writeString(12, 'fmt ');
            view.setUint32(16, 16, true);
            view.setUint16(20, 1, true);
            view.setUint16(22, 1, true);
            view.setUint32(24, sampleRate, true);
            view.setUint32(28, sampleRate * 2, true);
            view.setUint16(32, 2, true);
            view.setUint16(34, 16, true);
            writeString(36, 'data');
            view.setUint32(40, dataLength, true);
            return buffer;
        }

        function onResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            const t = Date.now() * 0.001;

            heart.rotation.y += 0.01;
            heart.scale.setScalar(0.2 + Math.sin(t * 4) * 0.02);
            heart.position.y = Math.sin(t) * 0.3;

            // Flower particles
            for(let i = flowerParticles.length - 1; i >= 0; i--) {
                const p = flowerParticles[i];
                p.mesh.position.add(p.velocity);
                p.mesh.rotation.z += 0.02;
                p.life -= 0.005;
                p.mesh.scale.setScalar(p.life);
                if(p.life <= 0) {
                    scene.remove(p.mesh);
                    flowerParticles.splice(i, 1);
                }
            }

            renderer.render(scene, camera);
        }

        window.onload = init;
    </script>
</body>
</html>
